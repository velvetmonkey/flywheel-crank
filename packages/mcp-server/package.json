{
  "name": "@velvetmonkey/flywheel-crank",
  "version": "1.27.45",
  "description": "Deterministic vault mutations for Obsidian via MCP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "flywheel-crank": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velvetmonkey/flywheel-crank.git"
  },
  "bugs": {
    "url": "https://github.com/velvetmonkey/flywheel-crank/issues"
  },
  "homepage": "https://github.com/velvetmonkey/flywheel-crank#readme",
  "author": "velvetmonkey",
  "keywords": [
    "mcp",
    "mcp-server",
    "obsidian",
    "vault-management",
    "markdown",
    "claude",
    "deterministic",
    "git-integration",
    "wikilinks",
    "knowledge-graph",
    "ai-agents",
    "mutation-tools"
  ],
  "scripts": {
    "build": "npx esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external && chmod +x dist/index.js",
    "dev": "npx esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:battle-hardening": "vitest run test/battle-hardening/",
    "test:golden": "vitest run test/golden/",
    "test:fuzzing": "vitest run test/battle-hardening/fuzzing.test.ts",
    "test:wsl-paths": "vitest run test/platform/wsl-paths.test.ts",
    "test:platform": "vitest run test/platform/",
    "test:workflows": "vitest run test/workflows/",
    "test:integration": "vitest run test/integration/",
    "test:wikilinks": "vitest run test/workflows/wikilink-loop.test.ts test/integration/entity-sync.test.ts",
    "test:docs": "vitest run test/docs/",
    "test:policy": "vitest run test/core/policy/",
    "test:undo": "vitest run test/tools/undo-sequences.test.ts",
    "test:coldstart": "vitest run test/coldstart/",
    "test:concurrency": "vitest run test/stress/same-file-races.test.ts test/stress/last-write-wins.test.ts",
    "test:ci": "vitest run --reporter=github-actions",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@velvetmonkey/vault-core": "^1.27.45",
    "gray-matter": "^4.0.3",
    "simple-git": "^3.22.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "esbuild": "^0.19.8",
    "fast-check": "^3.15.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "Apache-2.0",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
